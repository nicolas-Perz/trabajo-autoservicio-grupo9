<%- include('partials/head', { titulo: "Libros", empresa: "nombre-empresa", cssPage: "libros" }) %>
    <%- include('partials/header', { empresa, pagina, mostrarNav }) %>

        <main>
            <h2>
                <%= presentacion %>
            </h2>

            <div class="contenedor-categoria" id="contenedor-categoria">
                <button class="categoria-btn active" data-categoria="Todos">Todos</button>
                <button class="categoria-btn" data-categoria="Ciencia ficción">Ciencia ficción</button>
                <button class="categoria-btn" data-categoria="Fantasía">Fantasía</button>
                <button class="categoria-btn" data-categoria="Terror">Terror</button>
                <button class="categoria-btn" data-categoria="Misterio">Misterio</button>
                <button class="categoria-btn" data-categoria="Drama">Drama</button>
            </div>

            <!-- Lista de libros -->
            <div class="contenedor-producto" id="contenedor-libros">
                <% librosArray.forEach(libro=> { %>
                    <div class="tarjeta-libro">
                        <img src="<%= libro.imagen %>" alt="<%= libro.titulo %>">
                        <h3>
                            <%= libro.titulo %>
                        </h3>
                        <p class="libro-genero">Género: <%= libro.genero %>
                        </p>
                        <p class="libro-precio">Precio: $<%= libro.precio %>
                        </p>
                        <div class="libro-acciones">
                            <button class="btn-restar" data-id="<%= libro.id %>">-</button>
                            <span class="cantidad" id="cantidad-<%= libro.id %>">0</span>
                            <button class="btn-sumar" data-id="<%= libro.id %>">+</button>
                        </div>
                    </div>
                    <% }); %>
            </div>
        </main>

        <%- include('partials/footer', { alumnos, mostrarBotonLogin, mostrarBotonSalir }) %>